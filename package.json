{
  "name": "mosique-backend",
  "version": "1.0.0",
  "description": "Mosique — Spotify-inspired music app backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migration:create": "sequelize-cli migration:generate --name",
    "db:seed": "sequelize-cli db:seed:all"
  },
  "keywords": [
    "mosique",
    "music",
    "streaming",
    "api"
  ],
  "author": "Mosique Team",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.0",
    "nodemailer": "^9.0.3",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
